DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=
DJANGO_CSRF_TRUSTED_ORIGINS=

# JWT app_token: shared secret between Django and Next.js (keep internal, never commit real values)
DJANGO_JWT_SECRET=
# BOOTSTRAP_SECRET: short-lived secret for Next.js 鈫?Django bootstrap handshake
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DJANGO_BOOTSTRAP_SECRET=

DB_NAME=DB_NAME
DB_USER=DB_USER
DB_PASSWORD=DB_PASSWORD
DB_HOST=DB_HOST
DB_PORT=3306
DB_SSL_CA=ca.pem

# 預備email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ntubook.com
NOTIFICATION_FROM_EMAIL=noreply@ntubook.com